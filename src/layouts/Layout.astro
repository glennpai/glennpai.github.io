---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/chi.png" />
		<meta name="generator" content={Astro.generator} />
		<title>Christopher Glenn</title>
	</head>
	<body>
		<a href="#main-content" class="skip-link">Skip to main content</a>

		<div class="content">
			<Header />
			<main id="main-content">
				<slot />
			</main>
			<Footer />
		</div>
	</body>
</html>

<style>
	:root {
		--primary-color: #EDCC6F;
		--secondary-color: #829AB1;
		--background-color: #2B2C41;
	}

	html {
		height: 100%;
		font-family: "Menlo", "Meslo LG", monospace;
		font-weight: 400;
		font-size: 14px;
		line-height: 1.725;
		background-color: var(--background-color);
		color: white;
	}

	body {
		max-width: 48rem;
		margin-left: auto;
		margin-right: auto;
		padding-left: 2rem;
		padding-right: 2rem;
	}

	.content {
		width: 100%;
		min-height: 100%;
		display: flex;
		flex-direction: column;
		padding-top: 4rem;
		padding-bottom: 4rem;
	}

	.skip-link {
		position: absolute;
		top: -40px;
		left: 0;
		background-color: var(--background-color);
		color: var(--primary-color);
		padding: 8px 16px;
		text-decoration: none;
		border-radius: 4px;
		font-size: 14px;
		z-index: 1000;
	}

	.skip-link:focus {
		top: 0;
	}

	#main-content {
		margin-top: 2rem;
		margin-bottom: 2rem;
	}
</style>

